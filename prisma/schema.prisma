// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  // URLs are now handled in prisma.config.ts
}

generator client {
  provider = "prisma-client-js"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  SENT
  PAID
}

enum BookingPhotoCategory {
  BEFORE
  AFTER
  DAMAGE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  name      String
  role      String   @default("ADMIN")
  passwordResetTokens PasswordResetToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  email     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String
  address   String?
  bookings  Booking[]
  promoCodeUsages PromoCodeUsage[]
  createdAt DateTime  @default(now())
}

model PromoCode {
  id               String           @id @default(uuid())
  code             String           @unique
  discountPercent  Float
  maxUses           Int
  maxUsesPerClient  Int
  expiresAt         DateTime
  isActive          Boolean          @default(true)
  bookings          Booking[]
  usages            PromoCodeUsage[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([isActive, expiresAt])
}

model PromoCodeUsage {
  id                String    @id @default(uuid())
  promoCodeId       String
  promoCode         PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  bookingId         String    @unique
  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  discountPercent   Float
  discountAmount    Float
  createdAt         DateTime  @default(now())

  @@index([promoCodeId, clientId])
}

model Service {
  id              String    @id @default(uuid())
  name            String    
  basePrice       Float     
  durationMinutes Int       
  primaryBookings Booking[] @relation("PrimaryBookingService")
  bookings        Booking[] @relation("BookingToServices")
}

model VehicleCategory {
  id            String    @id @default(uuid())
  name          String    
  priceModifier Float     
  bookings      Booking[]
}

model AddOn {
  id                 String    @id @default(uuid())
  name               String    
  price              Float     
  additionalDuration Int       
  bookings           Booking[] @relation("BookingToAddOns")
}

model Booking {
  id                String          @id @default(uuid())
  dateTime          DateTime
  endTime           DateTime
  status            BookingStatus   @default(PENDING)
  language          String          @default("de")
  vehicleModel      String
  notes             String?
  imageUrls         String[]        @default([])

  photos BookingPhoto[]
  galleryProjects GalleryProject[] @relation("GalleryProjectBooking")

  clientId          String
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  serviceId         String
  service           Service         @relation("PrimaryBookingService", fields: [serviceId], references: [id])
  services          Service[]       @relation("BookingToServices")

  vehicleCategoryId String
  vehicleCategory   VehicleCategory @relation(fields: [vehicleCategoryId], references: [id])

  addOns            AddOn[]         @relation("BookingToAddOns")
  invoice           Invoice?

  promoCodeId            String?
  promoCode              PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoDiscountPercent   Float?
  promoDiscountAmount    Float           @default(0)
  promoCodeUsage         PromoCodeUsage?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([promoCodeId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique 
  issuedAt      DateTime      @default(now())
  dueDate       DateTime
  totalAmount   Float         
  vatRate       Float         @default(0)
  status        InvoiceStatus @default(SENT)
  language      String        @default("de")
  pdfUrl        String?       
  sentAt        DateTime?
  paidAt        DateTime?
  reminderSentAt DateTime?
  
  // Custom Overrides (so admin can change target info without corrupting base data)
  emailOverride String?       
  recipientName String?
  clientAddress String?
  businessAddress String      @default("Sternmatt 4, 6242 Wauwil")
  serviceDate   DateTime?
  promoCode     String?
  promoDiscountPercent Float?
  promoDiscountAmount  Float  @default(0)
  companyUid    String?       @default("CHE-122.222.222") // The UID shown in your invoice mock

  bookingId     String?       @unique
  booking       Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]

  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id           String   @id @default(uuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String   // e.g., "Schwertransport", "Innenreinigung", "Zusatz Addon"
  quantity     Float    @default(1.0)
  unit         String   @default("Stk.") // Stk., h, etc.
  pricePerUnit Float    
}

model BookingPhoto {
  id             String               @id @default(uuid())
  bookingId      String?
  booking        Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  galleryGroupId String
  storagePath    String               @unique
  category       BookingPhotoCategory
  isPublished    Boolean              @default(false)
  publishedAt    DateTime?
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())

  @@index([bookingId, category])
  @@index([galleryGroupId, category, sortOrder])
  @@index([isPublished, category, createdAt])
}

model GalleryProject {
  id          String              @id @default(uuid())
  title       String              @default("Neues Galerie-Projekt")
  bookingId   String?
  booking     Booking?            @relation("GalleryProjectBooking", fields: [bookingId], references: [id], onDelete: SetNull)
  comparisons GalleryComparison[]
  mediaAssets GalleryMediaAsset[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([bookingId])
  @@index([createdAt])
}

model GalleryMediaAsset {
  id               String         @id @default(uuid())
  projectId        String
  project          GalleryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storagePath      String         @unique
  originalFileName String?
  mimeType         String
  fileSize         Int

  cropX            Float          @default(0)
  cropY            Float          @default(0)
  cropScale        Float          @default(1)

  createdAt        DateTime       @default(now())

  usedAsBefore GalleryComparison? @relation("GalleryComparisonBeforeAsset")
  usedAsAfter  GalleryComparison? @relation("GalleryComparisonAfterAsset")

  @@index([projectId, createdAt])
}

model GalleryComparison {
  id            String             @id @default(uuid())
  projectId     String
  project       GalleryProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label         String?
  beforeAssetId String?            @unique
  afterAssetId  String?            @unique
  beforeAsset   GalleryMediaAsset? @relation("GalleryComparisonBeforeAsset", fields: [beforeAssetId], references: [id], onDelete: SetNull)
  afterAsset    GalleryMediaAsset? @relation("GalleryComparisonAfterAsset", fields: [afterAssetId], references: [id], onDelete: SetNull)
  isPublished   Boolean            @default(false)
  publishedAt   DateTime?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([projectId, sortOrder])
  @@index([isPublished, publishedAt])
}

model AvailabilityBlock {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  fullDay   Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())

  @@index([startTime, endTime])
}

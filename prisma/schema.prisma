// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  // URLs are now handled in prisma.config.ts
}

generator client {
  provider = "prisma-client-js"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  SENT
  PAID
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  phone     String
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Service {
  id              String    @id @default(uuid())
  name            String    
  basePrice       Float     
  durationMinutes Int       
  primaryBookings Booking[] @relation("PrimaryBookingService")
  bookings        Booking[] @relation("BookingToServices")
}

model VehicleCategory {
  id            String    @id @default(uuid())
  name          String    
  priceModifier Float     
  bookings      Booking[]
}

model AddOn {
  id                 String    @id @default(uuid())
  name               String    
  price              Float     
  additionalDuration Int       
  bookings           Booking[] @relation("BookingToAddOns")
}

model Booking {
  id                String          @id @default(uuid())
  dateTime          DateTime        
  endTime           DateTime        
  status            BookingStatus   @default(PENDING)
  vehicleModel      String          
  notes             String?
  imageUrls         String[]        @default([])

  clientId          String
  client            Client          @relation(fields: [clientId], references: [id])
  serviceId         String
  service           Service         @relation("PrimaryBookingService", fields: [serviceId], references: [id])
  services          Service[]       @relation("BookingToServices")
  vehicleCategoryId String
  vehicleCategory   VehicleCategory @relation(fields: [vehicleCategoryId], references: [id])
  addOns            AddOn[]         @relation("BookingToAddOns")
  invoice           Invoice?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique 
  issuedAt      DateTime      @default(now())
  dueDate       DateTime
  totalAmount   Float         
  vatRate       Float         @default(7.7) // Default Swiss VAT percentage
  status        InvoiceStatus @default(SENT)
  language      String        @default("de")
  pdfUrl        String?       
  sentAt        DateTime?
  paidAt        DateTime?
  reminderSentAt DateTime?
  
  // Custom Overrides (so admin can change target info without corrupting base data)
  emailOverride String?       
  recipientName String?
  companyUid    String?       @default("CHE-122.222.222") // The UID shown in your invoice mock

  bookingId     String?       @unique
  booking       Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]

  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id           String   @id @default(uuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String   // e.g., "Schwertransport", "Innenreinigung", "Zusatz Addon"
  quantity     Float    @default(1.0)
  unit         String   @default("Stk.") // Stk., h, etc.
  pricePerUnit Float    
}

model AvailabilityBlock {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  fullDay   Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())

  @@index([startTime, endTime])
}
